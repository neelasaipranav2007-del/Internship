{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/src/index.js" },
    { "source": "/uploads/(.*)", "destination": "/server/src/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
